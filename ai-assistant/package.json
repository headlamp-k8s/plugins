{
  "name": "@headlamp-k8s/ai-assistant",
  "version": "0.3.0-alpha",
  "description": "Headlamp's AI Assistant",
  "type": "module",
  "scripts": {
    "start": "headlamp-plugin start",
    "build": "headlamp-plugin build",
    "format": "headlamp-plugin format",
    "lint": "headlamp-plugin lint",
    "lint-fix": "headlamp-plugin lint --fix",
    "package": "headlamp-plugin package",
    "tsc": "headlamp-plugin tsc",
    "check": "npm run format -- --check && npm run lint && npm run tsc && npm run test && npm --prefix packages/ai-common run check --if-present",
    "e2e": "node e2e/run-ai-assistant-e2e.ts",
    "e2e:playwright": "playwright test --config e2e/playwright.config.ts",
    "storybook": "headlamp-plugin storybook",
    "storybook-build": "headlamp-plugin storybook-build",
    "test": "vitest run --config node_modules/@kinvolk/headlamp-plugin/config/vite.config.mjs --exclude \"**/packages/**\" --exclude \"**/node_modules/**\" --exclude \"e2e/**\"",
    "i18n": "headlamp-plugin i18n"
  },
  "keywords": [
    "headlamp",
    "headlamp-plugin",
    "kubernetes",
    "kubernetes-ui",
    "kubernetes-debugging",
    "plugins"
  ],
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "devDependencies": {
    "@kinvolk/headlamp-plugin": "^0.14.0",
    "@playwright/test": "1.61.1",
    "tsx": "^4.22.4"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.45",
    "@headlamp-k8s/ai-common": "file:./packages/ai-common",
    "@headlamp-k8s/ai-ui": "file:./packages/ai-ui",
    "@iconify/react": "^4.0.0",
    "@langchain/anthropic": "~1.4.0",
    "@langchain/core": "^1.1.20",
    "@langchain/deepseek": "^1.0.27",
    "@langchain/google-genai": "^2.1.16",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/mistralai": "^1.0.4",
    "@langchain/ollama": "^1.2.2",
    "@langchain/openai": "^1.2.6",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@monaco-editor/react": "^4.5.2",
    "@types/prismjs": "^1.26.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "langchain": "^1.2.19",
    "notistack": "^3.0.1",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.5",
    "use-between": "^1.3.5",
    "zod": "^4.1.12"
  },
  "overrides": {
    "typescript": "5.6.2",
    "ws": "^8.18.0",
    "@anthropic-ai/sdk": "~0.95.2",
    "@ag-ui/core": {
      "zod": "$zod"
    },
    "@ag-ui/client": {
      "zod": "$zod"
    }
  }
}
