{
  "name": "@headlamp-k8s/ai-assistant",
  "version": "0.2.0-alpha",
  "description": "Headlamp's AI Assistant",
  "type": "module",
  "scripts": {
    "start": "headlamp-plugin start",
    "build": "headlamp-plugin build",
    "format": "headlamp-plugin format",
    "lint": "headlamp-plugin lint",
    "lint-fix": "headlamp-plugin lint --fix",
    "package": "headlamp-plugin package",
    "tsc": "headlamp-plugin tsc",
    "check": "npm run format -- --check && npm run lint && npm run tsc && node_modules/.bin/vitest run --config node_modules/@kinvolk/headlamp-plugin/config/vite.config.mjs --exclude '**/packages/**' --exclude '**/node_modules/**'",
    "storybook": "headlamp-plugin storybook",
    "storybook-build": "headlamp-plugin storybook-build",
    "test": "headlamp-plugin test",
    "i18n": "headlamp-plugin i18n"
  },
  "keywords": [
    "headlamp",
    "headlamp-plugin",
    "kubernetes",
    "kubernetes-ui",
    "kubernetes-debugging",
    "plugins"
  ],
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "devDependencies": {
    "@kinvolk/headlamp-plugin": "^0.14.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/deepseek": "1.0.27",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/mistralai": "^1.1.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "@monaco-editor/react": "^4.5.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "jszip": "^3.10.1",
    "langchain": "^1.4.5",
    "notistack": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.4",
    "use-between": "^1.3.5",
    "zod": "^4.1.12"
  },
  "overrides": {
    "typescript": "5.6.2",
    "ws": "8.21.0",
    "vitest": "^3.2.6"
  }
}
