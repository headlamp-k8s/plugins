{
  "name": "@headlamp-k8s/ai-common",
  "version": "0.1.0-alpha",
  "description": "Shared AI assistant, MCP, and LangChain library for Headlamp",
  "type": "module",
  "exports": {
    "./agent/holmesClient": "./src/agent/holmesClient.ts",
    "./agent/MockHolmesAgent": "./src/agent/MockHolmesAgent.ts",
    "./agent/agentTypes": "./src/agent/agentTypes.ts",
    "./agent/debugLog": "./src/agent/debugLog.ts",
    "./ai/manager": "./src/ai/manager.ts",
    "./ai/prompts": "./src/ai/prompts.ts",
    "./components/mcpOutput/MCPArgumentProcessor": "./src/components/mcpOutput/MCPArgumentProcessor.ts",
    "./config/modelConfig": "./src/config/modelConfig.ts",
    "./langchain/LangChainManager": "./src/langchain/LangChainManager.ts",
    "./langchain/PromptTemplates": "./src/langchain/PromptTemplates.ts",
    "./langchain/formatters/MCPOutputFormatter": "./src/langchain/formatters/MCPOutputFormatter.ts",
    "./langchain/tools/ToolBase": "./src/langchain/tools/ToolBase.ts",
    "./langchain/tools/ToolManager": "./src/langchain/tools/ToolManager.ts",
    "./langchain/tools/ToolOrchestrator": "./src/langchain/tools/ToolOrchestrator.ts",
    "./langchain/tools/kubernetes/KubernetesTool": "./src/langchain/tools/kubernetes/KubernetesTool.ts",
    "./langchain/tools/kubernetes/types": "./src/langchain/tools/kubernetes/types.ts",
    "./langchain/tools/registry": "./src/langchain/tools/registry.ts",
    "./mcp/MCPClientCore": "./src/mcp/MCPClientCore.ts",
    "./mcp/MCPToolRouter": "./src/mcp/MCPToolRouter.ts",
    "./mcp/MCPEmbeddingRouter": "./src/mcp/MCPEmbeddingRouter.ts",
