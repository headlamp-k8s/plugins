    "./mcp/types": "./src/mcp/types.ts",
    "./mcp/mcpServerConfig": "./src/mcp/mcpServerConfig.ts",
    "./mock-testing-model/MockTestingModel": "./src/mock-testing-model/MockTestingModel.ts",
    "./mock-testing-model/builtinFixtures": "./src/mock-testing-model/builtinFixtures.ts",
    "./mock-testing-agent/MockTestingAgent": "./src/mock-testing-agent/MockTestingAgent.ts",
    "./mock-testing-agent/builtinFixtures": "./src/mock-testing-agent/builtinFixtures.ts",
    "./approval/InlineToolApprovalManager": "./src/approval/InlineToolApprovalManager.ts",
    "./approval/ToolApprovalManager": "./src/approval/ToolApprovalManager.ts",
    "./managers/ProviderConfigManager": "./src/managers/ProviderConfigManager.ts",
    "./managers/ToolConfigManager": "./src/managers/ToolConfigManager.ts",
    "./prompts/promptLinks": "./src/prompts/promptLinks.ts",
    "./skills/skillParser": "./src/skills/skillParser.ts",
    "./skills/SkillLoader": "./src/skills/SkillLoader.ts",
    "./skills/SkillConfigManager": "./src/skills/SkillConfigManager.ts",
    "./skills/SkillManager": "./src/skills/SkillManager.ts",
    "./skills/SkillRouter": "./src/skills/SkillRouter.ts",
    "./skills/EmbeddingRouter": "./src/skills/EmbeddingRouter.ts",
    "./skills/BrowserSkillAdapters": "./src/skills/BrowserSkillAdapters.ts",
    "./providers/providerAutoDetect": "./src/providers/providerAutoDetect.ts",
    "./context/contextGenerator": "./src/context/contextGenerator.ts",
    "./langchain/tools/MCPClientAdapter": "./src/langchain/tools/MCPClientAdapter.ts"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "tsc": "tsc --noEmit",
    "format": "prettier --check \"**/*.ts\" --ignore-path .gitignore",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"src/**/*.ts\"",
    "check": "npm run format && npm run lint && npm run tsc && npm run test"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@headlamp-k8s"
    ],
    "rules": {
      "indent": "off",
      "max-len": "off",
      "newline-per-chained-call": "off",
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }]
    }
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@ag-ui/client": "^0.0.57",
    "@langchain/anthropic": "^1.4.1",
    "@langchain/core": "^1.1.49",
    "@langchain/deepseek": "^1.0.27",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/mistralai": "^1.1.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "jszip": "^3.10.1",
    "langchain": "^1.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@headlamp-k8s/eslint-config": "^0.6.0",
    "eslint": "^8.57.1",
    "prettier": "^2.8.8",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  }
}
